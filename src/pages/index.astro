---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header class="site-header">
		<div class="container nav-wrap">
			<a class="brand" href="/">SoftWorks</a>
			<nav aria-label="Primary">
				<a href="#services">Services</a>
				<a href="#process">Process</a>
				<a href="#contact">Contact</a>
				<div class="theme-switcher" role="group" aria-label="Theme mode">
					<button type="button" data-theme-value="light" aria-pressed="false">
						<svg class="theme-icon" viewBox="0 0 24 24" aria-hidden="true">
							<circle cx="12" cy="12" r="4.4"></circle>
							<path d="M12 2.5v2.3M12 19.2v2.3M2.5 12h2.3M19.2 12h2.3M5.2 5.2l1.6 1.6M17.2 17.2l1.6 1.6M18.8 5.2l-1.6 1.6M6.8 17.2l-1.6 1.6"></path>
						</svg>
						<span>Light</span>
					</button>
					<button type="button" data-theme-value="dark" aria-pressed="false">
						<svg class="theme-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M14.5 3.2a8.8 8.8 0 1 0 6.3 15.1A9.6 9.6 0 0 1 14.5 3.2Z"></path>
						</svg>
						<span>Dark</span>
					</button>
					<button type="button" data-theme-value="auto" aria-pressed="false">
						<svg class="theme-icon" viewBox="0 0 24 24" aria-hidden="true">
							<rect x="3" y="5" width="18" height="14" rx="2"></rect>
							<path d="M9.8 19V5M9.8 12h11.2"></path>
						</svg>
						<span>Auto</span>
					</button>
				</div>
				<label class="theme-select-wrap" for="theme-mode">
					<span class="sr-only">Theme mode</span>
					<select id="theme-mode" data-theme-select aria-label="Theme mode">
						<option value="auto">Auto</option>
						<option value="light">Light</option>
						<option value="dark">Dark</option>
					</select>
				</label>
			</nav>
		</div>
	</header>

	<main>
		<section class="hero container">
			<p class="eyebrow">Perth, Western Australia</p>
			<h1>RAG Solutions Built for Accounting Firms</h1>
			<p>
				SoftWorks helps accounting practices turn internal knowledge into reliable, searchable
				AI assistants using Retrieval-Augmented Generation.
			</p>
			<a class="button" href="#contact">Book a Discovery Call</a>
		</section>

		<section id="services" class="container section">
			<h2>Core Services</h2>
			<div class="grid cards">
				<article class="card">
					<h3>Knowledge Base Setup</h3>
					<p>
						Centralize firm policies, tax references, and SOPs into a searchable foundation for
						RAG.
					</p>
				</article>
				<article class="card">
					<h3>Secure Retrieval Pipelines</h3>
					<p>
						Build retrieval workflows with role-based access so staff get accurate answers from
						the right documents.
					</p>
				</article>
				<article class="card">
					<h3>Workflow Integration</h3>
					<p>
						Embed assistants into existing accounting workflows to reduce research time and
						improve consistency.
					</p>
				</article>
			</div>
		</section>

		<section id="process" class="container section">
			<h2>How We Work</h2>
			<ol class="steps">
				<li><strong>Discover:</strong> We map your current information flow and compliance needs.</li>
				<li><strong>Design:</strong> We define a practical RAG architecture for your firm size.</li>
				<li><strong>Deploy:</strong> We launch, monitor, and tune for answer quality and trust.</li>
			</ol>
		</section>

		<section id="contact" class="container section contact">
			<h2>Start with a Pilot</h2>
			<p>
				Planning a first internal AI assistant for your Perth accounting team? SoftWorks can help
				you deploy a safe, useful pilot in weeks.
			</p>
			<a class="button" href="mailto:hello@softworks.example">hello@softworks.example</a>
		</section>
	</main>

	<footer class="site-footer">
		<div class="container">
			<p>SoftWorks • Perth, Western Australia</p>
		</div>
	</footer>
</Layout>

---
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<header class="site-header">
		<div class="container nav-wrap">
			<a class="brand" href="/">BlobPics</a>
			<nav aria-label="Primary">
				<a href="#services">Services</a>
				<a href="#process">Workflow</a>
				<a href="#contact">Contact</a>
				<div class="theme-switcher" role="group" aria-label="Theme mode">
					<button type="button" data-theme-value="light" aria-pressed="false">
						<svg class="theme-icon" viewBox="0 0 24 24" aria-hidden="true">
							<circle cx="12" cy="12" r="4.4"></circle>
							<path d="M12 2.5v2.3M12 19.2v2.3M2.5 12h2.3M19.2 12h2.3M5.2 5.2l1.6 1.6M17.2 17.2l1.6 1.6M18.8 5.2l-1.6 1.6M6.8 17.2l-1.6 1.6"></path>
						</svg>
						<span>Light</span>
					</button>
					<button type="button" data-theme-value="dark" aria-pressed="false">
						<svg class="theme-icon" viewBox="0 0 24 24" aria-hidden="true">
							<path d="M14.5 3.2a8.8 8.8 0 1 0 6.3 15.1A9.6 9.6 0 0 1 14.5 3.2Z"></path>
						</svg>
						<span>Dark</span>
					</button>
					<button type="button" data-theme-value="auto" aria-pressed="false">
						<svg class="theme-icon" viewBox="0 0 24 24" aria-hidden="true">
							<rect x="3" y="5" width="18" height="14" rx="2"></rect>
							<path d="M9.8 19V5M9.8 12h11.2"></path>
						</svg>
						<span>Auto</span>
					</button>
				</div>
				<label class="theme-select-wrap" for="theme-mode">
					<span class="sr-only">Theme mode</span>
					<select id="theme-mode" data-theme-select aria-label="Theme mode">
						<option value="auto">Auto</option>
						<option value="light">Light</option>
						<option value="dark">Dark</option>
					</select>
				</label>
			</nav>
		</div>
	</header>

	<main>
		<section class="hero container">
			<p class="eyebrow">Perth, Western Australia</p>
			<h1>Picture Editing That Makes Every Shot Publish-Ready</h1>
			<p>
				BlobPics helps brands, studios, and online sellers clean, retouch, and optimize photos
				for web, print, and campaigns.
			</p>
			<a class="button" href="#contact">Request a Sample Edit</a>
		</section>

		<section id="services" class="container section">
			<h2>Core Services</h2>
			<div class="grid cards">
				<article class="card">
					<h3>Portrait Retouching</h3>
					<p>
						Natural skin cleanup, color balancing, and detail recovery for professional and
						editorial portraits.
					</p>
				</article>
				<article class="card">
					<h3>Product Photo Cleanup</h3>
					<p>
						Background removal, dust and scratch fixes, and consistent shadows for ecommerce-ready
						catalogs.
					</p>
				</article>
				<article class="card">
					<h3>Creative Color Grading</h3>
					<p>
						Custom looks for campaign sets, social content, and lookbooks with consistent tone
						across every image.
					</p>
				</article>
			</div>
		</section>

		<section id="process" class="container section">
			<h2>How We Work</h2>
			<ol class="steps">
				<li><strong>Upload:</strong> Share your photos and style references via your preferred channel.</li>
				<li><strong>Edit:</strong> Our team applies retouching, cleanup, and grading to spec.</li>
				<li><strong>Deliver:</strong> Receive web and print-ready exports with quick revision rounds.</li>
			</ol>
		</section>

		<section id="contact" class="container section contact">
			<h2>Start with a Trial Batch</h2>
			<p>
				Need polished visuals for your next launch? BlobPics can edit a trial set so you can check
				quality, turnaround, and style fit.
			</p>
			<a class="button" href="mailto:hello@blobpics.example">hello@blobpics.example</a>
		</section>
	</main>

	<footer class="site-footer">
		<div class="container">
			<p>BlobPics • Perth, Western Australia</p>
		</div>
	</footer>
</Layout>

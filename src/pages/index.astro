---
import Layout from "../layouts/Layout.astro";
---

<Layout>
	<header class="site-header">
		<div class="container nav-wrap">
			<a class="brand" href="/">BlobPics</a>
			<nav aria-label="Primary">
				<a href="#services">Services</a>
				<a href="#process">Workflow</a>
				<a href="#portfolio">Portfolio</a>
				<a href="#pricing">Pricing</a>
				<a href="#faq">FAQ</a>
				<a href="#contact">Contact</a>
				<div
					class="theme-switcher"
					role="group"
					aria-label="Theme mode"
				>
					<button
						type="button"
						data-theme-value="light"
						aria-pressed="false"
					>
						<svg
							class="theme-icon"
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<circle cx="12" cy="12" r="4.4"></circle>
							<path
								d="M12 2.5v2.3M12 19.2v2.3M2.5 12h2.3M19.2 12h2.3M5.2 5.2l1.6 1.6M17.2 17.2l1.6 1.6M18.8 5.2l-1.6 1.6M6.8 17.2l-1.6 1.6"
							></path>
						</svg>
						<span>Light</span>
					</button>
					<button
						type="button"
						data-theme-value="dark"
						aria-pressed="false"
					>
						<svg
							class="theme-icon"
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<path
								d="M14.5 3.2a8.8 8.8 0 1 0 6.3 15.1A9.6 9.6 0 0 1 14.5 3.2Z"
							></path>
						</svg>
						<span>Dark</span>
					</button>
					<button
						type="button"
						data-theme-value="auto"
						aria-pressed="false"
					>
						<svg
							class="theme-icon"
							viewBox="0 0 24 24"
							aria-hidden="true"
						>
							<rect x="3" y="5" width="18" height="14" rx="2"
							></rect>
							<path d="M9.8 19V5M9.8 12h11.2"></path>
						</svg>
						<span>Auto</span>
					</button>
				</div>
				<label class="theme-select-wrap" for="theme-mode">
					<span class="sr-only">Theme mode</span>
					<select
						id="theme-mode"
						data-theme-select
						aria-label="Theme mode"
					>
						<option value="auto">Auto</option>
						<option value="light">Light</option>
						<option value="dark">Dark</option>
					</select>
				</label>
			</nav>
		</div>
	</header>

	<main>
		<section class="hero container page-section" id="top">
			<p class="eyebrow">Perth, Western Australia</p>
			<h1>AI Picture Editing That Makes Every Shot Publish-Ready</h1>
			<p>
				BlobPics combines AI-assisted workflows with expert review to
				clean, retouch, and optimize photos for web, print, and
				campaigns.
			</p>
			<div class="chip-row">
				<span>24-48 hour turnaround</span>
				<span>Human QA on every batch</span>
				<span>Web + print exports</span>
			</div>
			<a class="button" href="#contact">Request a Sample Edit</a>
		</section>

		<section class="container section scroll-section page-section">
			<div class="split">
				<div>
					<h2>Built as a One-Page Editing Studio</h2>
					<p>
						Everything you need is in this single scroll: services,
						process, examples, pricing, and FAQs. No extra pages, no
						extra clicks.
					</p>
				</div>
				<div class="stats">
					<article class="kpi">
						<h3>1,200+</h3>
						<p>images edited monthly</p>
					</article>
					<article class="kpi">
						<h3>98%</h3>
						<p>first-pass approval rate</p>
					</article>
					<article class="kpi">
						<h3>2 rounds</h3>
						<p>of revisions included</p>
					</article>
				</div>
			</div>
		</section>

		<section
			id="services"
			class="container section scroll-section page-section"
		>
			<h2>Core Services</h2>
			<div class="grid cards">
				<article class="card">
					<h3>AI Portrait Retouching</h3>
					<p>
						AI-assisted skin cleanup and color balancing, finalized
						by editors for professional and editorial portraits.
					</p>
				</article>
				<article class="card">
					<h3>AI Product Photo Cleanup</h3>
					<p>
						Automated background removal, dust and scratch fixes,
						and consistent shadows for ecommerce-ready catalogs.
					</p>
				</article>
				<article class="card">
					<h3>AI-Guided Color Grading</h3>
					<p>
						Model-assisted look matching for campaign sets, social
						content, and lookbooks with consistent tone across every
						image.
					</p>
				</article>
			</div>
		</section>

		<section
			id="process"
			class="container section scroll-section page-section"
		>
			<h2>How We Work</h2>
			<ol class="steps">
				<li>
					<strong>Upload:</strong> Share your photos and style references
					via your preferred channel.
				</li>
				<li>
					<strong>Edit:</strong> Our team applies retouching, cleanup, and
					grading to spec.
				</li>
				<li>
					<strong>Deliver:</strong> Receive web and print-ready exports
					with quick revision rounds.
				</li>
			</ol>
		</section>

		<section
			id="portfolio"
			class="container section scroll-section page-section"
		>
			<h2>Example Project Types</h2>
			<div class="grid portfolio-grid">
				<article class="card">
					<h3>Fashion Ecommerce Pack</h3>
					<p>
						200 SKUs, background cleanup, mannequin smoothing,
						consistent white balance.
					</p>
				</article>
				<article class="card">
					<h3>Corporate Headshot Refresh</h3>
					<p>
						Natural retouching and lighting correction across team
						portrait sets.
					</p>
				</article>
				<article class="card">
					<h3>Creator Campaign Batch</h3>
					<p>
						Cross-platform crop variants and matching grades for
						socials and print assets.
					</p>
				</article>
			</div>
			<blockquote class="quote">
				“BlobPics turned our mixed product photos into a consistent
				catalog in two days.”
			</blockquote>
		</section>

		<section
			id="pricing"
			class="container section scroll-section page-section"
		>
			<h2>Simple Pricing</h2>
			<div class="grid pricing-grid">
				<article class="card">
					<h3>Starter</h3>
					<p>Best for small batches and test runs.</p>
					<p><strong>From AUD $2.50 / image</strong></p>
				</article>
				<article class="card">
					<h3>Growth</h3>
					<p>For recurring monthly catalog updates.</p>
					<p><strong>From AUD $1.80 / image</strong></p>
				</article>
				<article class="card">
					<h3>Studio</h3>
					<p>High-volume teams with dedicated QA workflow.</p>
					<p><strong>Custom quote</strong></p>
				</article>
			</div>
		</section>

		<section id="faq" class="container section scroll-section page-section">
			<h2>Frequently Asked Questions</h2>
			<div class="faq-list">
				<article class="card">
					<h3>Do you only use AI?</h3>
					<p>
						No. AI handles repetitive base edits, then editors
						review and finalize every batch.
					</p>
				</article>
				<article class="card">
					<h3>What file formats do you support?</h3>
					<p>
						JPG, PNG, TIFF, and PSD workflows with export options
						for web and print.
					</p>
				</article>
				<article class="card">
					<h3>Can we request custom looks?</h3>
					<p>
						Yes. Share references and we will build a style profile
						for your ongoing projects.
					</p>
				</article>
			</div>
		</section>

		<section
			id="contact"
			class="container section contact scroll-section page-section"
		>
			<h2>Start with a Trial Batch</h2>
			<p>
				Need polished visuals for your next launch? Try BlobPics AI
				editing with human quality control and see the turnaround for
				yourself.
			</p>
			<a class="button" href="mailto:hello@blobpics.example"
				>hello@blobpics.example</a
			>
		</section>
	</main>

	<footer class="site-footer">
		<div class="container">
			<p>BlobPics • Perth, Western Australia</p>
		</div>
	</footer>

	<script>
		import { gsap } from 'gsap';
		import { ScrollTrigger } from 'gsap/ScrollTrigger';

		gsap.registerPlugin(ScrollTrigger);

		// Deck of Cards Animation
		const sections = gsap.utils.toArray('.page-section');
		
		// Set Z-index so the first section is on top of the stack
		sections.forEach((sec, i) => {
			(sec as HTMLElement).style.zIndex = (sections.length - i).toString();
		});

		const tl = gsap.timeline({
			scrollTrigger: {
				trigger: 'main',
				pin: true,
				start: `top top+=${document.querySelector('.site-header')?.clientHeight || 0}`,
				end: () => `+=${sections.length * 100}%`,
				scrub: 1,
			}
		});

		sections.forEach((section, i) => {
			if (i === sections.length - 1) return; // Don't animate the last section away
			
			// Slide the top card up and away (simulating moving it off the deck)
			tl.to(section as HTMLElement, {
				yPercent: -120, // Move it up entirely off the screen
				rotationZ: -4, // Add a slight tilt for character
				scale: 0.85,
				opacity: 0,
				duration: 1,
				ease: "power2.inOut"
			});
		});
	</script>
</Layout>
